# Database
DATABASE_URL="postgresql://user:password@localhost:5432/formbot?schema=public"

# Next Auth
NEXTAUTH_URL="https://gway.uz "
NEXTAUTH_SECRET="your-nextauth-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Telegram
TELEGRAM_BOT_TOKEN="your-main-bot-token-if-needed"

# Encryption (to encrypt telegram tokens in DB if you want extra security)
ENCRYPTION_KEY="your-encryption-key-32-chars"
