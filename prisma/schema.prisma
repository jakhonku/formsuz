// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          String    @default("FREE") // FREE, PRO, BUSINESS
  planExpiresAt DateTime?
  accounts      Account[]
  sessions      Session[]
  bots          Bot[]
  forms         Form[]
  votingBots    VotingBot[]
  reviews       Review[]
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      @default(5)
  content   String   @db.Text
  isApproved Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Form {
  id           String   @id @default(cuid())
  googleFormId String   @unique
  title        String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata     Json?    // Questions and other structure info
  linkedSheetId String?
  bots          Bot[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Bot {
  id                  String   @id @default(cuid())
  name                String
  telegramToken       String   @unique
  telegramBotUsername String?
  status              String   @default("active") // active, inactive
  formId              String
  form                Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses           Response[]
  messages            ChatMessage[]
  // Per-bot toggles for Google integrations: { calendar, docs, slides, drive, gmail, meet, tasks }
  integrations        Json?
  integrationLogs     IntegrationLog[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([formId])
}

model IntegrationLog {
  id         String   @id @default(cuid())
  botId      String
  bot        Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  responseId String?
  service    String   // calendar | docs | slides | drive | gmail | meet | tasks
  success    Boolean  @default(false)
  resultUrl  String?  @db.Text
  resultId   String?
  error      String?  @db.Text
  payload    Json?    // metadata about the run (e.g., title, recipient)
  createdAt  DateTime @default(now())

  @@index([botId, createdAt])
  @@index([responseId])
}

model Response {
  id                String   @id @default(cuid())
  botId             String
  bot               Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  data              Json     // The responses collected from Telegram
  status            String   @default("completed") // in_progress, completed
  chatId            String?  // Telegram chat id
  lastQuestionIndex Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([botId, status, createdAt])
  @@index([botId, chatId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  botId          String
  bot            Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  chatId         String   // Telegram chat id
  content        String?  @db.Text
  type           String   @default("text") // text, voice, image, file
  fileUrl        String?  @db.Text
  sender         String   @default("admin") // admin, user
  senderName     String?
  senderUsername String?
  senderPhoto    String?
  createdAt      DateTime @default(now())

  @@index([botId, chatId, createdAt])
}

model VotingBot {
  id                  String      @id @default(cuid())
  name                String
  title               String      // Konkurs nomi (masalan: "Eng yaxshi sanatkor 2026")
  description         String?     @db.Text
  telegramToken       String      @unique
  telegramBotUsername String?
  status              String      @default("active") // active, inactive
  oneVotePerUser      Boolean     @default(true)
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates          Candidate[]
  votes               Vote[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([userId])
}

model Candidate {
  id           String    @id @default(cuid())
  name         String
  description  String?   @db.Text
  photoUrl     String?   @db.Text
  votingBotId  String
  votingBot    VotingBot @relation(fields: [votingBotId], references: [id], onDelete: Cascade)
  votes        Vote[]
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
}

model Vote {
  id             String    @id @default(cuid())
  votingBotId    String
  votingBot      VotingBot @relation(fields: [votingBotId], references: [id], onDelete: Cascade)
  candidateId    String
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  chatId         String    // Telegram chat id of voter
  voterName      String?
  voterUsername  String?
  createdAt      DateTime  @default(now())

  @@unique([votingBotId, chatId])
  @@index([candidateId])
}
