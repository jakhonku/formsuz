// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  bots          Bot[]
  forms         Form[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Form {
  id           String   @id @default(cuid())
  googleFormId String   @unique
  title        String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata     Json?    // Questions and other structure info
  linkedSheetId String?
  bots          Bot[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Bot {
  id                  String   @id @default(cuid())
  name                String
  telegramToken       String   @unique
  telegramBotUsername String?
  status              String   @default("active") // active, inactive
  formId              String
  form                Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses           Response[]
  messages            ChatMessage[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Response {
  id                String   @id @default(cuid())
  botId             String
  bot               Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  data              Json     // The responses collected from Telegram
  status            String   @default("completed") // in_progress, completed
  chatId            String?  // Telegram chat id
  lastQuestionIndex Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ChatMessage {
  id             String   @id @default(cuid())
  botId          String
  bot            Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  chatId         String   // Telegram chat id
  content        String?  @db.Text
  type           String   @default("text") // text, voice, image, file
  fileUrl        String?  @db.Text
  sender         String   @default("admin") // admin, user
  senderName     String?
  senderUsername String?
  senderPhoto    String?
  createdAt      DateTime @default(now())
}
